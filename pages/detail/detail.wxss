.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 16rpx;
}

.section {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.section:last-of-type {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.section-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.section-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

.contact-hidden {
  color: var(--warning);
  background: #FFF7ED;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.info-item {
  width: 50%;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.safety-warning {
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.warning-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 12rpx;
}

.warning-content {
  font-size: 26rpx;
  color: #92400E;
  line-height: 1.8;
}
