.form-header {
  text-align: center;
  padding: 40rpx 0;
}

.form-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.form-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
}

.form-card {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.switch-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

.submit-section {
  padding: 20rpx 0 60rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.submit-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 20rpx;
}
