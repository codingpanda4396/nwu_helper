generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ActivityStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum BannerTargetType {
  ACTIVITY
  SERVICE
  ABOUT
  TAB
  URL
}

enum CommunityPostStatus {
  PENDING
  VISIBLE
  HIDDEN
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  name         String
  username     String?    @unique
  phone        String?    @unique
  openid       String?    @unique
  role         UserRole   @default(STUDENT)
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  summary          String?
  categoryId       String
  address          String
  phone            String?
  businessHours    String?
  coverImageUrl    String?
  qrImageUrl       String?
  sortOrder        Int              @default(100)
  status           MerchantStatus   @default(PENDING)
  category         Category         @relation(fields: [categoryId], references: [id])
  serviceCategory  ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId String?
  activities       Activity[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([categoryId])
  @@index([serviceCategoryId])
  @@index([status, sortOrder])
}

model Banner {
  id         String           @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String
  targetType BannerTargetType @default(TAB)
  targetId   String?
  url        String?
  sortOrder  Int              @default(100)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model WechatEntryConfig {
  id          String   @id @default("home-wechat-entry")
  title       String   @default("加入西大圈微信")
  description String   @default("领活动、问优惠、推荐好店、反馈问题，都从这里开始。")
  buttonText  String   @default("添加微信")
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceCategory {
  id        String     @id @default(cuid())
  name      String
  key       String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isActive, sortOrder])
}

model CommunityPost {
  id             String              @id @default(cuid())
  type           String
  title          String
  summary        String
  content        String              @default("")
  authorNickname String?
  contact        String?
  source         String              @default("admin")
  viewCount      Int                 @default(0)
  likeCount      Int                 @default(0)
  commentCount   Int                 @default(0)
  likedSessionIds Json               @default("[]")
  status         CommunityPostStatus @default(VISIBLE)
  sortOrder      Int                 @default(100)
  publishedAt    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, type, sortOrder, publishedAt])
}

model Activity {
  id          String         @id @default(cuid())
  title       String
  description String?
  merchantId  String
  coverImage  String?
  sortOrder   Int            @default(100)
  status      ActivityStatus @default(DRAFT)
  startAt     DateTime
  endAt       DateTime
  merchant    Merchant       @relation(fields: [merchantId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, startAt, endAt, sortOrder])
  @@index([merchantId])
}
