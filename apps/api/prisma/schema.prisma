generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ActivityStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum BannerTargetType {
  ACTIVITY
  SERVICE
  ABOUT
  TAB
  URL
}

enum CommunityPostStatus {
  PENDING
  VISIBLE
  HIDDEN
  REJECTED
}

enum ImageType {
  MENU
  ENVIRONMENT
  OTHER
}

enum FeedbackType {
  SUGGESTION
  COMPLAINT
  COOPERATION
  OTHER
}

enum FeedbackStatus {
  PENDING
  PROCESSING
  RESOLVED
}

model User {
  id             String     @id @default(cuid())
  name           String
  username       String?    @unique
  phone          String?    @unique
  openid         String?    @unique
  role           UserRole   @default(STUDENT)
  passwordHash   String?
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  lastActiveAt   DateTime?
  loginCount     Int        @default(0)
  registerSource String?
  viewHistories  ViewHistory[]
  favorites      Favorite[]
  feedbacks      Feedback[]
  loginLogs      UserLoginLog[]
  activities     UserActivity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  summary          String?
  categoryId       String
  address          String
  phone            String?
  businessHours    String?
  coverImageUrl    String?
  qrImageUrl       String?
  wechatLabel      String?
  privateDomainNote String?
  defaultChannelId String?
  avgPrice         Float?
  latitude         Float?
  longitude        Float?
  tags             String[]         @default([])
  sortOrder        Int              @default(100)
  status           MerchantStatus   @default(PENDING)
  category         Category         @relation(fields: [categoryId], references: [id])
  serviceCategory  ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId String?
  activities       Activity[]
  images           MerchantImage[]
  viewHistories    ViewHistory[]
  favorites        Favorite[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([categoryId])
  @@index([serviceCategoryId])
  @@index([defaultChannelId])
  @@index([status, sortOrder])
}

model MerchantImage {
  id         String    @id @default(cuid())
  merchantId String
  imageUrl   String
  type       ImageType @default(OTHER)
  sortOrder  Int       @default(100)
  merchant   Merchant  @relation(fields: [merchantId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([merchantId, type])
}

model Banner {
  id         String           @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String
  targetType BannerTargetType @default(TAB)
  targetId   String?
  url        String?
  sortOrder  Int              @default(100)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model WechatEntryConfig {
  id          String   @id @default("home-wechat-entry")
  title       String   @default("加入竹影校园微信")
  description String   @default("领活动、问优惠、推荐好店、反馈问题，都从这里开始。")
  buttonText  String   @default("添加微信")
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceCategory {
  id        String     @id @default(cuid())
  name      String
  key       String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isActive, sortOrder])
}

model CommunityPost {
  id             String              @id @default(cuid())
  type           String
  title          String
  summary        String
  content        String              @default("")
  authorNickname String?
  contact        String?
  source         String              @default("student")
  viewCount      Int                 @default(0)
  likeCount      Int                 @default(0)
  commentCount   Int                 @default(0)
  likedSessionIds Json               @default("[]")
  status         CommunityPostStatus @default(PENDING)
  sortOrder      Int                 @default(100)
  publishedAt    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, type, sortOrder, publishedAt])
}

model Activity {
  id          String         @id @default(cuid())
  title       String
  description String?
  merchantId  String
  channelId   String?
  source      String?
  coverImage  String?
  sortOrder   Int            @default(100)
  status      ActivityStatus @default(DRAFT)
  startAt     DateTime
  endAt       DateTime
  merchant    Merchant       @relation(fields: [merchantId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, startAt, endAt, sortOrder])
  @@index([merchantId])
  @@index([channelId])
}

model AttributionChannel {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  source      String?
  campaign    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, key])
}

model ViewHistory {
  id         String   @id @default(cuid())
  userId     String?
  merchantId String
  sessionId  String?
  user       User?    @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([merchantId, createdAt])
  @@index([createdAt])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  merchantId String
  user       User     @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, merchantId])
  @@index([userId])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String?
  content   String
  contact   String?
  type      FeedbackType   @default(SUGGESTION)
  status    FeedbackStatus @default(PENDING)
  reply     String?
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
}

model CampusConfig {
  id        String   @id @default("default")
  name      String   @default("西北大学")
  slug      String   @default("nwu")
  logo      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  action    String
  page      String?
  targetId  String?
  merchantId String?
  activityId String?
  channelId String?
  source    String?
  scene     String?
  platform  String
  ip        String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@index([page, createdAt])
  @@index([merchantId, createdAt])
  @@index([activityId, createdAt])
  @@index([channelId, createdAt])
  @@index([source, createdAt])
}

model UserLoginLog {
  id        String   @id @default(cuid())
  userId    String
  method    String
  platform  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([method, createdAt])
}

model UserDailySnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  newUsers    Int      @default(0)
  activeUsers Int      @default(0)
  loginCount  Int      @default(0)
  pageViews   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([date])
  @@index([date])
}
