generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  MERCHANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ActivityStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum BannerTargetType {
  ACTIVITY
  SERVICE
  ABOUT
  TAB
  URL
}

enum CommunityPostStatus {
  PENDING
  VISIBLE
  HIDDEN
  REJECTED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum OrderStatus {
  PENDING
  PAID
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum ImageType {
  MENU
  ENVIRONMENT
  OTHER
}

enum FeedbackType {
  SUGGESTION
  COMPLAINT
  COOPERATION
  OTHER
}

enum FeedbackStatus {
  PENDING
  PROCESSING
  RESOLVED
}

model User {
  id             String     @id @default(cuid())
  name           String
  username       String?    @unique
  phone          String?    @unique
  openid         String?    @unique
  role           UserRole   @default(STUDENT)
  passwordHash   String?
  status         UserStatus @default(ACTIVE)
  nickname       String?
  avatarUrl      String?
  lastLoginAt    DateTime?
  lastActiveAt   DateTime?
  loginCount     Int        @default(0)
  registerSource String?
  viewHistories  ViewHistory[]
  favorites      Favorite[]
  feedbacks      Feedback[]
  loginLogs      UserLoginLog[]
  activities     UserActivity[]
  teacherReviews TeacherReview[]
  materials      StudyMaterial[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  summary          String?
  categoryId       String
  address          String
  phone            String?
  businessHours    String?
  coverImageUrl    String?
  qrImageUrl       String?
  wechatLabel      String?
  privateDomainNote String?
  defaultChannelId String?
  ownerUserId      String?
  avgPrice         Float?
  latitude         Float?
  longitude        Float?
  tags             String[]         @default([])
  sortOrder        Int              @default(100)
  status           MerchantStatus   @default(PENDING)
  category         Category         @relation(fields: [categoryId], references: [id])
  serviceCategory  ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId String?
  activities       Activity[]
  images           MerchantImage[]
  viewHistories    ViewHistory[]
  favorites        Favorite[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([categoryId])
  @@index([serviceCategoryId])
  @@index([defaultChannelId])
  @@index([ownerUserId])
  @@index([status, sortOrder])
}

model MerchantImage {
  id         String    @id @default(cuid())
  merchantId String
  imageUrl   String
  type       ImageType @default(OTHER)
  sortOrder  Int       @default(100)
  merchant   Merchant  @relation(fields: [merchantId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([merchantId, type])
}

model Banner {
  id               String           @id @default(cuid())
  title            String
  subtitle         String?
  imageUrl         String
  targetType       BannerTargetType @default(TAB)
  targetId         String?
  url              String?
  sortOrder        Int              @default(100)
  isActive         Boolean          @default(true)
  promotionOrderId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model WechatEntryConfig {
  id          String   @id @default("home-wechat-entry")
  title       String   @default("加入竹影校园微信")
  description String   @default("领活动、问优惠、推荐好店、反馈问题，都从这里开始。")
  buttonText  String   @default("添加微信")
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DrivingPageConfig {
  id            String   @id @default("driving-page")
  title         String   @default("严选驾校")
  description   String   @default("课少也能稳稳学车，就近练车、灵活约课、流程透明。")
  promoImages   Json     @default("[]")
  qrImageUrl    String?
  qrTitle       String   @default("扫码咨询班型")
  qrDescription String   @default("报名优惠、练车时间和接送安排，以西大圈微信咨询为准。")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceCategory {
  id        String     @id @default(cuid())
  name      String
  key       String     @unique
  icon      String?
  sortOrder Int        @default(100)
  isActive  Boolean    @default(true)
  merchants Merchant[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isActive, sortOrder])
}

model CommunityPost {
  id             String              @id @default(cuid())
  type           String
  title          String
  summary        String
  content        String              @default("")
  authorNickname String?
  authorUserId   String?
  contact        String?
  source         String              @default("student")
  viewCount      Int                 @default(0)
  likeCount      Int                 @default(0)
  commentCount   Int                 @default(0)
  likedSessionIds Json               @default("[]")
  images         Json                @default("[]")
  status         CommunityPostStatus @default(PENDING)
  sortOrder      Int                 @default(100)
  publishedAt    DateTime            @default(now())
  comments       Comment[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, type, sortOrder, publishedAt])
}

model Activity {
  id               String         @id @default(cuid())
  title            String
  description      String?
  merchantId       String
  channelId        String?
  source           String?
  coverImage       String?
  sortOrder        Int            @default(100)
  status           ActivityStatus @default(DRAFT)
  startAt          DateTime
  endAt            DateTime
  promotionOrderId String?
  merchant         Merchant       @relation(fields: [merchantId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, startAt, endAt, sortOrder])
  @@index([merchantId])
  @@index([channelId])
}

model AttributionChannel {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  source      String?
  campaign    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, key])
}

model ViewHistory {
  id         String   @id @default(cuid())
  userId     String?
  merchantId String
  sessionId  String?
  user       User?    @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([merchantId, createdAt])
  @@index([createdAt])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  merchantId String
  user       User     @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, merchantId])
  @@index([userId])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String?
  content   String
  contact   String?
  type      FeedbackType   @default(SUGGESTION)
  status    FeedbackStatus @default(PENDING)
  reply     String?
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
}

model CampusConfig {
  id        String   @id @default("default")
  name      String   @default("西北大学")
  slug      String   @default("nwu")
  logo      String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  action    String
  page      String?
  targetId  String?
  merchantId String?
  activityId String?
  channelId String?
  source    String?
  scene     String?
  platform  String
  ip        String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@index([page, createdAt])
  @@index([merchantId, createdAt])
  @@index([activityId, createdAt])
  @@index([channelId, createdAt])
  @@index([source, createdAt])
}

model UserLoginLog {
  id        String   @id @default(cuid())
  userId    String
  method    String
  platform  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([method, createdAt])
}

model UserDailySnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  newUsers    Int      @default(0)
  activeUsers Int      @default(0)
  loginCount  Int      @default(0)
  pageViews   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model SmsCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

model Comment {
  id             String        @id @default(cuid())
  postId         String
  parentId       String?
  authorUserId   String?
  authorNickname String?
  content        String
  status         CommentStatus @default(VISIBLE)
  likeCount      Int           @default(0)
  createdAt      DateTime      @default(now())
  post           CommunityPost @relation(fields: [postId], references: [id])

  @@index([postId, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PromotionSlot {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  position    String
  pricePerDay Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PromotionOrder {
  id         String      @id @default(cuid())
  merchantId String
  slotId     String
  bannerId   String?
  activityId String?
  days       Int
  amount     Int
  status     OrderStatus @default(PENDING)
  startAt    DateTime?
  endAt      DateTime?
  paidAt     DateTime?
  createdAt  DateTime    @default(now())

  @@index([merchantId])
  @@index([status, endAt])
}

// ── 学业服务 ──

enum TeacherStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum MaterialStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

model Teacher {
  id            String          @id @default(cuid())
  name          String
  college       String          @default("")
  department    String          @default("")
  avatarUrl     String?
  addedByUserId String?
  status        TeacherStatus   @default(PENDING)
  avgGrading    Float           @default(0)
  avgAttendance Float           @default(0)
  avgDifficulty Float           @default(0)
  avgRecommend  Float           @default(0)
  avgExamFocus  Float           @default(0)
  reviewCount   Int             @default(0)
  reviews       TeacherReview[]
  courses       Course[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, name])
  @@index([college, name])
}

model TeacherReview {
  id         String       @id @default(cuid())
  teacherId  String
  userId     String
  courseName String       @default("")
  grading    Int
  attendance Int
  difficulty Int
  recommend  Int
  examFocus  Int
  comment    String       @default("")
  status     ReviewStatus @default(PENDING)
  teacher    Teacher      @relation(fields: [teacherId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([teacherId, status, createdAt])
  @@index([userId, createdAt])
}

model Course {
  id        String          @id @default(cuid())
  name      String
  teacherId String
  teacher   Teacher         @relation(fields: [teacherId], references: [id])
  materials StudyMaterial[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([name, teacherId])
  @@index([teacherId, name])
}

model StudyMaterial {
  id            String         @id @default(cuid())
  title         String
  description   String         @default("")
  courseId      String
  userId        String
  status        MaterialStatus @default(PENDING)
  viewCount     Int            @default(0)
  downloadCount Int            @default(0)
  course        Course         @relation(fields: [courseId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  files         MaterialFile[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([courseId, status, createdAt])
  @@index([userId, createdAt])
}

model MaterialFile {
  id         String        @id @default(cuid())
  materialId String
  fileName   String
  fileKey    String
  fileUrl    String
  fileSize   Int           @default(0)
  mimeType   String        @default("")
  material   StudyMaterial @relation(fields: [materialId], references: [id])
  createdAt  DateTime      @default(now())

  @@index([materialId])
}
