<view class="page">
  <view class="service-grid">
    <button wx:for="{{services}}" wx:key="id" class="service card {{activeServiceId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="selectService">
      <view class="icon">{{item.icon}}</view>
      <view class="name">{{item.name}}</view>
    </button>
  </view>

  <section-title title="推荐商家" hint="首版先展示已合作服务" />
  <view wx:if="{{list.length}}">
    <merchant-card wx:for="{{list}}" wx:key="id" merchant="{{item}}" bind:open="openMerchant" />
  </view>
  <empty-state wx:else title="这个服务正在招募商家" desc="你可以推荐靠谱商家，西大圈会优先联系。" action-text="推荐商家" bind:action="recommendMerchant" />
</view>
