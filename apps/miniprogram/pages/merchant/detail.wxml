<view class="detail" wx:if="{{merchant}}">
  <image class="cover" src="{{merchant.image}}" mode="aspectFill" />
  <view class="page body">
    <view class="head card">
      <view class="name">{{merchant.name}}</view>
      <view class="meta">★ {{merchant.rating}} · 人均 ¥{{merchant.avgPrice}} · {{merchant.distance}}</view>
      <view class="tags">
        <text wx:for="{{merchant.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="discount">{{merchant.discount}}</view>
    </view>

    <view class="info card">
      <view class="row"><text>地址</text><text>{{merchant.address}}</text></view>
      <view class="row"><text>营业</text><text>{{merchant.businessHours}}</text></view>
      <view class="actions">
        <button bindtap="copyAddress">复制地址</button>
        <button bindtap="openMap">导航</button>
        <button bindtap="joinGroup">加群咨询</button>
      </view>
    </view>

    <section-title title="商家亮点" />
    <view class="highlight-grid">
      <view wx:for="{{merchant.highlights}}" wx:key="*this" class="highlight card">{{item}}</view>
    </view>

    <section-title title="推荐菜单" />
    <view class="menu card">
      <view wx:for="{{merchant.menu}}" wx:key="name" class="menu-row">
        <text>{{item.name}}</text>
        <text>¥{{item.price}}</text>
      </view>
    </view>

    <section-title title="优惠券 / 套餐" />
    <coupon-card wx:for="{{merchantCoupons}}" wx:key="id" coupon="{{item}}" bind:claim="claimCoupon" />

    <section-title title="位置与咨询" />
    <view class="map card">地图位置将在接入经纬度后展示</view>
    <qrcode-block title="微信福利群" desc="进群咨询活动细节，后续支持真实二维码。" image="{{merchant.qrImage}}" bind:action="joinGroup" />

    <view class="promo card">更多西大周边优惠，关注西大圈。</view>
  </view>
</view>

<view class="page" wx:else>
  <empty-state title="没有找到这个商家" desc="可能是链接已失效，先回首页看看。" action-text="回到首页" bind:action="goHome" />
</view>
