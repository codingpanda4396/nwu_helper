.detail {
  min-height: 100vh;
  background: #f7f8fa;
}

.cover {
  width: 100%;
  height: 430rpx;
  background: #eef2f7;
}

.body {
  margin-top: -46rpx;
}

.head,
.info,
.menu,
.promo {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.name {
  color: #1f2933;
  font-size: 42rpx;
  font-weight: 900;
}

.meta {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 25rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tags text {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 22rpx;
}

.discount {
  margin-top: 18rpx;
  color: #ff8a1f;
  font-size: 34rpx;
  font-weight: 900;
}

.row,
.menu-row {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 14rpx 0;
  color: #1f2933;
  font-size: 26rpx;
  line-height: 1.4;
}

.row text:first-child {
  flex: 0 0 76rpx;
  color: #6b7280;
}

.actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.actions button {
  height: 66rpx;
  border-radius: 14rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.highlight-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.highlight {
  padding: 24rpx 10rpx;
  color: #1f2933;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.map {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 180rpx;
  margin-bottom: 18rpx;
  color: #6b7280;
  font-size: 25rpx;
  background: #edf8f3;
}

.promo {
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}
