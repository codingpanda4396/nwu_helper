.home {
  padding-top: 0;
}

.hero {
  margin: 0 -24rpx;
  padding: 42rpx 24rpx 28rpx;
  background: linear-gradient(135deg, #19b36b 0%, #34c789 58%, #ffb15f 100%);
}

.brand {
  color: #ffffff;
  font-size: 54rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.subtitle {
  margin: 8rpx 0 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 27rpx;
  line-height: 1.4;
}

.chooser {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
}

.chooser-title {
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 900;
}

.chooser-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.chooser-btn {
  flex: 0 0 auto;
  padding: 0 24rpx;
  height: 66rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #ff8a1f;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 66rpx;
}

.feature-grid {
  display: grid;
  gap: 16rpx;
}

.feature-food {
  display: grid;
  grid-template-columns: 136rpx 1fr;
  gap: 18rpx;
  padding: 18rpx;
  text-align: left;
}

.feature-food image {
  width: 136rpx;
  height: 110rpx;
  border-radius: 12rpx;
}

.feature-post {
  display: block;
  margin-bottom: 16rpx;
  padding: 22rpx;
  text-align: left;
}

.feature-type {
  color: #19b36b;
  font-size: 23rpx;
  font-weight: 900;
}

.feature-title {
  color: #1f2933;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
}

.feature-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.feedback {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.feedback button {
  height: 76rpx;
  border-radius: 16rpx;
  color: #19b36b;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 76rpx;
}
