<view class="page home">
  <view class="hero">
    <view class="brand">西大圈</view>
    <view class="subtitle">发现西北大学周边好店与校园生活服务</view>
  </view>

  <banner-swiper banners="{{banners}}" bind:bannertap="onBannerTap" />

  <section-title title="今日校园福利" hint="优惠、套餐和周边好店" />
  <activity-card wx:for="{{activities}}" wx:key="id" item="{{item}}" bind:open="onActivityOpen" />

  <section-title title="今天吃什么" hint="选择困难时交给西大圈" />
  <view class="chooser card">
    <view>
      <view class="chooser-title">帮我选一家</view>
      <view class="chooser-desc">{{recommendation || '点击按钮，随机推荐一家适合今天的店。'}}</view>
    </view>
    <button class="chooser-btn" bindtap="chooseFood">帮我选</button>
  </view>

  <section-title title="精选美食" hint="后台运营推荐" />
  <view class="feature-grid">
    <button wx:for="{{featuredFoods}}" wx:key="id" class="feature-food card" data-id="{{item.id}}" bindtap="onFoodOpen">
      <image src="{{item.image || '/assets/images/merchant-food-001.jpg'}}" mode="aspectFill" />
      <view>
        <view class="feature-title">{{item.name}}</view>
        <view class="feature-desc">{{item.recommendation || item.discount}}</view>
      </view>
    </button>
  </view>

  <section-title title="校园热帖" hint="审核后展示" />
  <button wx:for="{{featuredPosts}}" wx:key="id" class="feature-post card" data-id="{{item.id}}" bindtap="openPost">
    <view class="feature-type">{{item.type}}</view>
    <view class="feature-title">{{item.title}}</view>
    <view class="feature-desc">{{item.summary}}</view>
  </button>

  <section-title title="西大圈入口" action-text="了解更多" bind:action="openAbout" />
  <qrcode-block title="加入西大圈" desc="发现更多校园福利、拼饭信息和周边服务。" image="/assets/images/qr-placeholder.jpg" bind:action="showQrToast" />

  <view class="feedback">
    <button bindtap="showFeedbackToast">我要推荐商家</button>
    <button bindtap="showFeedbackToast">我要反馈</button>
  </view>
</view>
