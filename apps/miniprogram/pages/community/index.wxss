.top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx;
}

.title {
  color: #1f2933;
  font-size: 40rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.4;
}

.top button {
  flex: 0 0 auto;
  width: 112rpx;
  height: 64rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #19b36b;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.tabs {
  display: flex;
  width: 100%;
  margin: 24rpx 0 18rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  padding: 0 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  color: #53606f;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.tab.active {
  color: #ffffff;
  background: #19b36b;
}

.notice {
  padding: 16rpx 20rpx;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  color: #99610f;
  background: #fff5e8;
  font-size: 24rpx;
}

.submit {
  margin-top: 18rpx;
  padding: 24rpx;
}

.submit-title {
  margin-bottom: 16rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 900;
}

.submit input,
.submit textarea {
  width: 100%;
  min-height: 74rpx;
  margin-bottom: 14rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #f3f5f7;
  color: #1f2933;
  font-size: 25rpx;
  box-sizing: border-box;
}

.submit textarea {
  min-height: 160rpx;
  padding-top: 18rpx;
}

.submit button,
.like-btn {
  height: 70rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #19b36b;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 70rpx;
}

.detail {
  padding: 28rpx;
}

.back {
  width: 180rpx;
  height: 62rpx;
  margin-bottom: 22rpx;
  border-radius: 14rpx;
  color: #1f2933;
  background: #eef2f7;
  font-size: 24rpx;
  line-height: 62rpx;
}

.detail-type {
  color: #19b36b;
  font-size: 24rpx;
  font-weight: 900;
}

.detail-title {
  margin-top: 12rpx;
  color: #1f2933;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.3;
}

.detail-meta {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.detail-content {
  margin-top: 26rpx;
  color: #344054;
  font-size: 28rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.like-btn {
  width: 150rpx;
  margin-top: 26rpx;
}
