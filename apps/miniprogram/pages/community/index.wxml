<view class="page community">
  <view wx:if="{{selectedPost}}" class="detail card">
    <button class="back" bindtap="closePost">返回讨论区</button>
    <view class="detail-type">{{selectedPost.type}}</view>
    <view class="detail-title">{{selectedPost.title}}</view>
    <view class="detail-meta">{{selectedPost.authorNickname || '匿名同学'}} · {{selectedPost.time}} · {{selectedPost.viewCount || 0}} 浏览</view>
    <view class="detail-content">{{selectedPost.content || selectedPost.summary}}</view>
    <button class="like-btn" bindtap="likePost">赞 {{selectedPost.likeCount || 0}}</button>
  </view>

  <block wx:else>
  <view class="top card">
    <view>
      <view class="title">西大圈</view>
      <view class="desc">校园墙、求助、拼饭、二手和校园信息，发布后审核展示</view>
    </view>
    <button bindtap="publish">发布</button>
  </view>

  <view wx:if="{{showForm}}" class="submit card">
    <view class="submit-title">发布投稿</view>
    <input placeholder="类型，如 校园墙/拼饭/二手" value="{{form.type}}" data-field="type" bindinput="updateForm" />
    <input placeholder="标题" value="{{form.title}}" data-field="title" bindinput="updateForm" />
    <textarea placeholder="正文内容" value="{{form.content}}" data-field="content" bindinput="updateForm" />
    <input placeholder="昵称" value="{{form.authorNickname}}" data-field="authorNickname" bindinput="updateForm" />
    <input placeholder="联系方式，仅后台可见" value="{{form.contact}}" data-field="contact" bindinput="updateForm" />
    <button bindtap="submitPost">提交审核</button>
  </view>

  <scroll-view class="tabs" scroll-x enable-flex>
    <button wx:for="{{types}}" wx:key="*this" class="tab {{activeType === item ? 'active' : ''}}" data-type="{{item}}" bindtap="setType">{{item}}</button>
  </scroll-view>

  <view class="notice">发言内容需遵守校园社区规范</view>

  <community-post-card wx:for="{{list}}" wx:key="id" post="{{item}}" bind:open="openPost" />
  <empty-state wx:if="{{!list.length}}" title="暂无帖子" desc="换个分类看看，或稍后再来。" />
  </block>
</view>
