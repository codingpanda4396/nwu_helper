.intro {
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.logo {
  color: #19b36b;
  font-size: 54rpx;
  font-weight: 900;
}

.slogan {
  margin-top: 12rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.body {
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.social {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 18rpx;
  margin-top: 20rpx;
}

.social button,
.actions button {
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.social button {
  color: #1f2933;
  background: #f2f4f7;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.actions button {
  color: #ffffff;
  background: #19b36b;
}
