.hero-img {
  width: 100%;
  height: 340rpx;
  border-radius: 24rpx;
  background: #eef2f7;
}

.intro {
  position: relative;
  padding: 26rpx;
  margin-top: -38rpx;
}

.badge {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #19b36b;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 18rpx;
  color: #1f2933;
  font-size: 40rpx;
  font-weight: 900;
}

.summary {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.yard {
  width: 100%;
  height: 300rpx;
  border-radius: 22rpx;
  background: #eef2f7;
}

.adv-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.adv {
  padding: 28rpx 16rpx;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.process {
  padding: 8rpx 24rpx;
}

.step {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  color: #1f2933;
  font-size: 27rpx;
  font-weight: 700;
}

.num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #ff8a1f;
  font-size: 23rpx;
  font-weight: 900;
}
