<view class="page">
  <image class="hero-img" src="{{drivingSchool.image}}" mode="aspectFill" />
  <view class="intro card">
    <view class="badge">西大圈合作推荐</view>
    <view class="title">{{drivingSchool.name}}</view>
    <view class="summary">{{drivingSchool.summary}}</view>
  </view>

  <section-title title="环境展示" />
  <image class="yard" src="{{drivingSchool.yardImage}}" mode="aspectFill" />

  <section-title title="服务优势" />
  <view class="adv-grid">
    <view wx:for="{{drivingSchool.advantages}}" wx:key="*this" class="adv card">{{item}}</view>
  </view>

  <section-title title="报名流程" />
  <view class="process card">
    <view wx:for="{{drivingSchool.process}}" wx:key="*this" class="step">
      <view class="num">{{index + 1}}</view>
      <view>{{item}}</view>
    </view>
  </view>

  <section-title title="咨询报名" />
  <qrcode-block title="驾校咨询二维码" desc="扫码咨询班型、价格、接送和练车安排。" image="{{drivingSchool.qrImage}}" bind:action="consult" />
</view>
