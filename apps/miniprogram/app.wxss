page {
  background: #f7f8fa;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(31, 41, 51, 0.07);
}

.muted {
  color: #6b7280;
}

.pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 23rpx;
  line-height: 1.3;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  border-radius: 16rpx;
  color: #ffffff;
  background: #19b36b;
  font-size: 28rpx;
  font-weight: 700;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 16rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 27rpx;
  font-weight: 700;
}

button {
  padding: 0;
  margin: 0;
  text-align: inherit;
  background: transparent;
}

button::after {
  border: 0;
}

image {
  display: block;
}
