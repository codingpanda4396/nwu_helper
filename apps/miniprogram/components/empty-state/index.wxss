.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 54rpx 34rpx;
  text-align: center;
}

.icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 44rpx;
}

.title {
  margin-top: 22rpx;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 900;
}

.desc {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.action {
  margin-top: 24rpx;
  padding: 0 26rpx;
  height: 64rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #19b36b;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 64rpx;
}
