.qr {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 22rpx;
}

image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 16rpx;
  background: #eef2f7;
}

.copy {
  flex: 1;
  min-width: 0;
}

.title {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.ghost {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 0 22rpx;
  height: 58rpx;
  border-radius: 14rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
}
