<button class="merchant card" bindtap="onTap">
  <image src="{{merchant.image}}" mode="aspectFill" />
  <view class="content">
    <view class="top">
      <view class="name">{{merchant.name}}</view>
      <view class="rating">★ {{merchant.rating}}</view>
    </view>
    <view class="meta">人均 ¥{{merchant.avgPrice}} · {{merchant.distance}}</view>
    <view class="tags">
      <text wx:for="{{merchant.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="discount">{{merchant.discount}}</view>
    <view class="desc">{{merchant.recommendation}}</view>
  </view>
</button>
