.coupon {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #ffe2c2;
  border-radius: 18rpx;
  background: #fff8ef;
}

.left {
  min-width: 0;
}

.title {
  color: #1f2933;
  font-size: 29rpx;
  font-weight: 900;
}

.desc,
.meta {
  margin-top: 7rpx;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.35;
}

.claim {
  flex: 0 0 auto;
  padding: 0 22rpx;
  height: 64rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #ff8a1f;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 64rpx;
}
