.activity {
  display: flex;
  overflow: hidden;
  min-height: 180rpx;
  margin-bottom: 18rpx;
}

image {
  width: 220rpx;
  height: 180rpx;
  flex: 0 0 auto;
}

.body {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tags text {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 21rpx;
}

.title {
  margin-top: 14rpx;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
}

.bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.discount {
  color: #ff8a1f;
  font-size: 28rpx;
  font-weight: 900;
}

.cta {
  color: #19b36b;
  font-size: 24rpx;
  font-weight: 700;
}
