.post {
  display: block;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.head,
.foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.type {
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: #19b36b;
  background: #e9f8f1;
  font-size: 22rpx;
}

.time,
.summary,
.foot {
  color: #6b7280;
  font-size: 23rpx;
}

.title {
  margin-top: 18rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.summary {
  margin-top: 10rpx;
  line-height: 1.45;
}

.foot {
  justify-content: flex-start;
  margin-top: 18rpx;
}
