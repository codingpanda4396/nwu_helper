.banner {
  width: 100%;
  height: 320rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.slide {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

image {
  width: 100%;
  height: 100%;
}

.copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 34rpx;
  color: #ffffff;
  text-align: left;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
}

.name {
  font-size: 38rpx;
  font-weight: 900;
}

.desc {
  margin-top: 8rpx;
  font-size: 25rpx;
}
